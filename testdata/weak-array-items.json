{
  "openapi": "3.0.0",
  "info": {
    "title": "Weak Array Items Demo",
    "version": "1.0.0"
  },
  "paths": {
    "/sync": {
      "post": {
        "operationId": "sync",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Done"
          }
        }
      }
    },
    "/items": {
      "get": {
        "operationId": "listItems",
        "responses": {
          "200": {
            "description": "Item list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
