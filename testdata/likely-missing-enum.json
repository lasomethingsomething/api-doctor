{
  "openapi": "3.0.0",
  "info": {
    "title": "Likely Missing Enum",
    "version": "1.0.0"
  },
  "paths": {
    "/weak-enum": {
      "get": {
        "operationId": "getWeakEnum",
        "responses": {
          "200": {
            "description": "Weak enum schema",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/strong-enum": {
      "get": {
        "operationId": "getStrongEnum",
        "responses": {
          "200": {
            "description": "Strong enum schema",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["open", "closed"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}